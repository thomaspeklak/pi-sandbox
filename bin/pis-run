#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
ROOT_DIR="$(cd "$BIN_DIR/.." && pwd)"

BROWSER_MODE=0
if [[ "${1:-}" == "--browser" ]]; then
  BROWSER_MODE=1
  shift
fi
if [[ "${PI_SBOX_BROWSER:-0}" == "1" ]]; then
  BROWSER_MODE=1
fi

CONFIG_FILE="${PI_SBOX_CONFIG_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/pi-sandbox/config.toml}"
RESOLVER="$ROOT_DIR/scripts/resolve-config.py"

for required in python3 jq podman; do
  if ! command -v "$required" >/dev/null 2>&1; then
    echo "Missing required dependency: $required" >&2
    exit 1
  fi
done

if [[ ! -f "$RESOLVER" ]]; then
  echo "Missing config resolver: $RESOLVER" >&2
  exit 1
fi

if ! CONFIG_JSON="$(python3 "$RESOLVER" --config "$CONFIG_FILE")"; then
  exit 1
fi

cfg() {
  jq -r "$1" <<<"$CONFIG_JSON"
}

IMAGE="$(cfg '.sandbox.image')"
CONTAINERFILE="$(cfg '.sandbox.containerfile')"
SANDBOX_PI_DIR="$(cfg '.sandbox.sandbox_pi_dir')"
HOST_PI_DIR="$(cfg '.sandbox.host_pi_dir')"
HOST_CLAUDE_DIR="$(cfg '.sandbox.host_claude_dir')"
CACHE_DIR="$(cfg '.sandbox.cache_dir')"
GITCFG_PATH="$(cfg '.sandbox.gitconfig_path')"
AUTH_KEY="$(cfg '.sandbox.auth_key')"
SIGN_KEY="$(cfg '.sandbox.sign_key')"
SETTINGS_TEMPLATE="$ROOT_DIR/agent/settings.example.json"
WORKDIR_SOURCE="${PI_SBOX_WORKDIR:-$PWD}"
WORKDIR="$(realpath "$WORKDIR_SOURCE")"
CONTAINER_WORKDIR="$WORKDIR_SOURCE"
if [[ "$CONTAINER_WORKDIR" != /* ]]; then
  CONTAINER_WORKDIR="$WORKDIR"
fi

mkdir -p "$CACHE_DIR" "$SANDBOX_PI_DIR/extensions"

if [[ ! -f "$CONTAINERFILE" ]]; then
  echo "Missing Containerfile: $CONTAINERFILE" >&2
  exit 1
fi
if [[ ! -f "$SANDBOX_PI_DIR/settings.json" ]]; then
  if [[ -f "$HOST_PI_DIR/settings.json" ]]; then
    cp "$HOST_PI_DIR/settings.json" "$SANDBOX_PI_DIR/settings.json"
    chmod 600 "$SANDBOX_PI_DIR/settings.json"
    echo "Bootstrapped sandbox settings from host: $HOST_PI_DIR/settings.json" >&2
  elif [[ -f "$SETTINGS_TEMPLATE" ]]; then
    cp "$SETTINGS_TEMPLATE" "$SANDBOX_PI_DIR/settings.json"
    chmod 600 "$SANDBOX_PI_DIR/settings.json"
    echo "Bootstrapped sandbox settings from template: $SETTINGS_TEMPLATE" >&2
  else
    echo "Missing sandbox settings: $SANDBOX_PI_DIR/settings.json" >&2
    exit 1
  fi
fi
if [[ ! -f "$SANDBOX_PI_DIR/extensions/guard.ts" ]]; then
  echo "Missing guard extension: $SANDBOX_PI_DIR/extensions/guard.ts" >&2
  exit 1
fi

mapfile -t BOOTSTRAP_FILES < <(cfg '.sandbox.bootstrap_files[]?')
for bootstrap_file in "${BOOTSTRAP_FILES[@]}"; do
  if [[ ! -f "$SANDBOX_PI_DIR/$bootstrap_file" && -f "$HOST_PI_DIR/$bootstrap_file" ]]; then
    cp "$HOST_PI_DIR/$bootstrap_file" "$SANDBOX_PI_DIR/$bootstrap_file"
    chmod 600 "$SANDBOX_PI_DIR/$bootstrap_file"
  fi
done

ensure_image() {
  if ! podman image exists "$IMAGE"; then
    echo "Building sandbox image: $IMAGE"
    podman build -t "$IMAGE" -f "$CONTAINERFILE" "$(dirname "$CONTAINERFILE")"
  fi
}

ensure_gitconfig() {
  if [[ -f "$GITCFG_PATH" ]]; then
    return
  fi

  mkdir -p "$(dirname "$GITCFG_PATH")"

  local name email
  name="$(git config --global user.name 2>/dev/null || true)"
  email="$(git config --global user.email 2>/dev/null || true)"

  [[ -n "$name" ]] || name="Pi Sandbox Agent"
  [[ -n "$email" ]] || email="pi-sandbox@example.invalid"

  cat >"$GITCFG_PATH" <<EOF
[user]
    name = $name
    email = $email
    signingkey = /home/dev/.ssh/pi-agent-signing.pub
[commit]
    gpgsign = true
[gpg]
    format = ssh
EOF
  chmod 600 "$GITCFG_PATH"
}

start_dedicated_agent() {
  local agent_env="$CACHE_DIR/ssh-agent.env"
  local agent_sock="$CACHE_DIR/ssh-agent.sock"

  if [[ -f "$agent_env" ]]; then
    # shellcheck disable=SC1090
    source "$agent_env"
  fi

  local agent_ok=1
  if [[ -z "${SSH_AGENT_PID:-}" || -z "${SSH_AUTH_SOCK:-}" || ! -S "${SSH_AUTH_SOCK:-}" ]]; then
    agent_ok=0
  elif ! kill -0 "${SSH_AGENT_PID:-0}" 2>/dev/null; then
    agent_ok=0
  fi

  if [[ "$agent_ok" == "0" ]]; then
    rm -f "$agent_sock"
    eval "$(ssh-agent -s -a "$agent_sock")" >/dev/null
    cat >"$agent_env" <<EOF
SSH_AUTH_SOCK=$SSH_AUTH_SOCK
SSH_AGENT_PID=$SSH_AGENT_PID
EOF
  fi

  if [[ -s "$AUTH_KEY" ]]; then
    if ! ssh-add -L 2>/dev/null | grep -qxF "$(cat "$AUTH_KEY.pub" 2>/dev/null || true)"; then
      if ! ssh-add "$AUTH_KEY" >/dev/null 2>&1; then
        echo "Warning: failed to add auth key to dedicated agent: $AUTH_KEY" >&2
      fi
    fi
  elif [[ -f "$AUTH_KEY" ]]; then
    echo "Warning: auth key file is empty: $AUTH_KEY" >&2
  fi

  if [[ -s "$SIGN_KEY" ]]; then
    if ! ssh-add -L 2>/dev/null | grep -qxF "$(cat "$SIGN_KEY.pub" 2>/dev/null || true)"; then
      if ! ssh-add "$SIGN_KEY" >/dev/null 2>&1; then
        echo "Warning: failed to add signing key to dedicated agent: $SIGN_KEY" >&2
      fi
    fi
  elif [[ -f "$SIGN_KEY" ]]; then
    echo "Warning: signing key file is empty: $SIGN_KEY" >&2
  fi
}

secret_lookup_from_attributes() {
  local attributes_json="$1"

  if ! command -v secret-tool >/dev/null 2>&1; then
    return 0
  fi

  local lookup_args=()
  while IFS=$'\t' read -r key value; do
    lookup_args+=("$key" "$value")
  done < <(jq -r 'to_entries[] | "\(.key)\t\(.value)"' <<<"$attributes_json")

  if [[ ${#lookup_args[@]} -eq 0 ]]; then
    return 0
  fi

  secret-tool lookup "${lookup_args[@]}" 2>/dev/null || true
}

start_browser_if_needed() {
  [[ "$BROWSER_MODE" == "1" ]] || return 0

  local enabled
  enabled="$(cfg '.browser.enabled')"
  if [[ "$enabled" != "true" ]]; then
    echo "Browser mode requested, but [browser].enabled is false in $CONFIG_FILE" >&2
    return 1
  fi

  local port browser_cmd profile_dir
  port="$(cfg '.browser.debug_port')"
  browser_cmd="$(cfg '.browser.command')"
  profile_dir="$(cfg '.browser.profile_dir')"

  if [[ -z "$browser_cmd" ]]; then
    echo "Browser mode requested, but [browser].command is empty in $CONFIG_FILE" >&2
    return 1
  fi

  if curl -fsS "http://127.0.0.1:${port}/json/version" >/dev/null 2>&1; then
    return 0
  fi

  if [[ "$browser_cmd" == */* ]]; then
    if [[ ! -x "$browser_cmd" ]]; then
      echo "Configured browser command is not executable: $browser_cmd" >&2
      return 1
    fi
  else
    if ! command -v "$browser_cmd" >/dev/null 2>&1; then
      echo "Configured browser command not found in PATH: $browser_cmd" >&2
      return 1
    fi
  fi

  mkdir -p "$profile_dir"

  local browser_args=()
  mapfile -t browser_args < <(cfg '.browser.command_args[]?')

  nohup "$browser_cmd" \
    "${browser_args[@]}" \
    --remote-debugging-port="$port" \
    --user-data-dir="$profile_dir" \
    --no-first-run \
    --no-default-browser-check \
    about:blank >/dev/null 2>&1 &

  sleep 1
}

ensure_image
ensure_gitconfig

SSH_SOCKET_TO_MOUNT="${SSH_AUTH_SOCK:-}"
if [[ -s "$AUTH_KEY" && -s "$SIGN_KEY" ]]; then
  start_dedicated_agent
  SSH_SOCKET_TO_MOUNT="$SSH_AUTH_SOCK"
fi

if [[ -z "$SSH_SOCKET_TO_MOUNT" || ! -S "$SSH_SOCKET_TO_MOUNT" ]]; then
  echo "No SSH agent socket available. Push/signing may fail." >&2
fi

start_browser_if_needed

ENV_FILE="$(mktemp -p "${XDG_RUNTIME_DIR:-/tmp}" pi-sbox-env.XXXXXX)"
chmod 600 "$ENV_FILE"
cleanup() {
  rm -f "$ENV_FILE"
}
trap cleanup EXIT

append_env_if_set() {
  local key="$1"
  local value="$2"
  if [[ -n "$value" ]]; then
    printf '%s=%s\n' "$key" "$value" >>"$ENV_FILE"
  fi
}

# Resolve configured secrets in order; first successful source wins per env var
mapfile -t SECRET_SPECS < <(cfg '.secrets[]? | @base64')
declare -A SECRET_VALUES=()
for encoded in "${SECRET_SPECS[@]}"; do
  spec_json="$(printf '%s' "$encoded" | base64 -d)"
  env_name="$(jq -r '.env' <<<"$spec_json")"

  if [[ -n "${SECRET_VALUES[$env_name]+x}" ]]; then
    continue
  fi

  source_type="$(jq -r '.source' <<<"$spec_json")"
  value=""

  case "$source_type" in
    env)
      from_env="$(jq -r '.from_env' <<<"$spec_json")"
      value="${!from_env:-}"
      ;;
    secret-tool)
      attrs_json="$(jq -c '.attributes' <<<"$spec_json")"
      value="$(secret_lookup_from_attributes "$attrs_json")"
      ;;
    *)
      ;;
  esac

  if [[ -n "$value" ]]; then
    SECRET_VALUES["$env_name"]="$value"
  fi
done

for env_name in "${!SECRET_VALUES[@]}"; do
  append_env_if_set "$env_name" "${SECRET_VALUES[$env_name]}"
done

# Explicit passthroughs from config
mapfile -t PASSTHROUGH_ENV < <(cfg '.sandbox.passthrough_env[]?')
for env_name in "${PASSTHROUGH_ENV[@]}"; do
  if [[ -n "${SECRET_VALUES[$env_name]+x}" ]]; then
    continue
  fi
  append_env_if_set "$env_name" "${!env_name:-}"
done

NETWORK_MODE="slirp4netns:allow_host_loopback=false"
if [[ "$BROWSER_MODE" == "1" ]]; then
  NETWORK_MODE="slirp4netns:allow_host_loopback=true"
fi

PODMAN_ARGS=(
  run --rm -it
  --pull=never
  --userns=keep-id
  --security-opt=no-new-privileges
  --security-opt=label=disable
  --cap-drop=all
  --pids-limit=4096
  --network "$NETWORK_MODE"
  -e HOME=/home/dev
  -e PI_CODING_AGENT_DIR=/home/dev/.pi/agent
  -e GIT_CONFIG_GLOBAL=/home/dev/.config/pi-sandbox/gitconfig
  -e SSH_AUTH_SOCK=/ssh-agent
  -e TERM
  -e COLORTERM
  -e EDITOR
  -e VISUAL
  --env-file "$ENV_FILE"
  -v "$WORKDIR:$CONTAINER_WORKDIR:rw"
  -w "$CONTAINER_WORKDIR"
  -v "$SANDBOX_PI_DIR:/home/dev/.pi/agent:rw"
  -v "$GITCFG_PATH:/home/dev/.config/pi-sandbox/gitconfig:ro"
)

read_roots=("$CONTAINER_WORKDIR" "/tmp" "/home/dev/.pi/agent")
write_roots=("$CONTAINER_WORKDIR" "/tmp" "/home/dev/.pi/agent")

mapfile -t ACTIVE_MOUNTS < <(jq -c --arg browser "$BROWSER_MODE" '.mounts[]? | select(.when == "always" or ($browser == "1" and .when == "browser"))' <<<"$CONFIG_JSON")
for mount_json in "${ACTIVE_MOUNTS[@]}"; do
  host_path="$(jq -r '.host' <<<"$mount_json")"
  container_path="$(jq -r '.container' <<<"$mount_json")"
  mode="$(jq -r '.mode' <<<"$mount_json")"
  kind="$(jq -r '.kind' <<<"$mount_json")"
  create="$(jq -r '.create' <<<"$mount_json")"
  optional="$(jq -r '.optional' <<<"$mount_json")"

  if [[ ! -e "$host_path" ]]; then
    if [[ "$create" == "true" ]]; then
      if [[ "$kind" == "file" ]]; then
        mkdir -p "$(dirname "$host_path")"
        touch "$host_path"
      else
        mkdir -p "$host_path"
      fi
    elif [[ "$optional" == "true" ]]; then
      continue
    else
      echo "Required mount source missing: $host_path" >&2
      exit 1
    fi
  fi

  PODMAN_ARGS+=( -v "$host_path:$container_path:$mode" )
  read_roots+=("$container_path")
  if [[ "$mode" == "rw" ]]; then
    write_roots+=("$container_path")
  fi
done

if [[ -n "$SSH_SOCKET_TO_MOUNT" && -S "$SSH_SOCKET_TO_MOUNT" ]]; then
  PODMAN_ARGS+=( -v "$SSH_SOCKET_TO_MOUNT:/ssh-agent" )
fi

if [[ -s "$AUTH_KEY.pub" ]]; then
  PODMAN_ARGS+=( -v "$AUTH_KEY.pub:/home/dev/.ssh/pi-agent-auth.pub:ro" )
fi
if [[ -s "$SIGN_KEY.pub" ]]; then
  PODMAN_ARGS+=( -v "$SIGN_KEY.pub:/home/dev/.ssh/pi-agent-signing.pub:ro" )
fi

READ_ROOTS_JSON="$(printf '%s\n' "${read_roots[@]}" | jq -R . | jq -sc 'map(select(length > 0)) | unique')"
WRITE_ROOTS_JSON="$(printf '%s\n' "${write_roots[@]}" | jq -R . | jq -sc 'map(select(length > 0)) | unique')"
PODMAN_ARGS+=(
  -e "PI_SBOX_GUARD_READ_ROOTS_JSON=$READ_ROOTS_JSON"
  -e "PI_SBOX_GUARD_WRITE_ROOTS_JSON=$WRITE_ROOTS_JSON"
)

mapfile -t BOOT_DIRS < <(cfg '.sandbox.container_boot_dirs[]?')
boot_dirs_quoted=()
for boot_dir in "${BOOT_DIRS[@]}"; do
  boot_dirs_quoted+=("$(printf '%q' "$boot_dir")")
done
BOOT_DIRS_CMD=""
if [[ ${#boot_dirs_quoted[@]} -gt 0 ]]; then
  BOOT_DIRS_CMD="mkdir -p ${boot_dirs_quoted[*]}; "
fi

if [[ "$BROWSER_MODE" == "1" ]]; then
  BROWSER_PORT="$(cfg '.browser.debug_port')"
  BROWSER_PI_SKILL_PATH="$(cfg '.browser.pi_skill_path // empty')"
  SKILL_ARG=""
  if [[ -n "$BROWSER_PI_SKILL_PATH" ]]; then
    SKILL_ARG=" --skill $(printf '%q' "$BROWSER_PI_SKILL_PATH")"
  fi
  CONTAINER_BOOT="${BOOT_DIRS_CMD}socat TCP-LISTEN:${BROWSER_PORT},fork,reuseaddr,bind=127.0.0.1 TCP:10.0.2.2:${BROWSER_PORT} >/tmp/pi-sbox-socat.log 2>&1 & exec pi --no-extensions -e /home/dev/.pi/agent/extensions/guard.ts${SKILL_ARG} \"\$@\""
else
  CONTAINER_BOOT="${BOOT_DIRS_CMD}exec pi --no-extensions -e /home/dev/.pi/agent/extensions/guard.ts \"\$@\""
fi

exec podman "${PODMAN_ARGS[@]}" "$IMAGE" bash -lc "$CONTAINER_BOOT" _ "$@"
